{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "target": "esnext",
    "module": "nodenext",
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    "rewriteRelativeImportExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "rootDir": "."
  },
  "include": ["./start-server.ts"],
  "exclude": ["**/node_modules"]
}
