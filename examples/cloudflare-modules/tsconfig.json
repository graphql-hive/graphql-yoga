{
  "compilerOptions": {
    "outDir": "./dist",
    "module": "nodenext",
    "target": "esnext",
    "lib": ["esnext"],
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "skipLibCheck": true,
    "types": ["@cloudflare/workers-types", "jest"],
    "ignoreDeprecations": "6.0",
    "rootDir": "."
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "__integration-tests__"]
}
